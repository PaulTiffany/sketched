verification/lean/ForcingKernel/.lake/
verification/lean/ForcingAnalysis/.lake/

# Python caches / packet staging
__pycache__/
packets/_stage/
.venv/

# External runtime checkout (pinned in verification/fabricpc_install_receipt.json)
fabric/FabricPC/
# Local agent and review workspaces
.claude/
.review/

# Reproducible archives and superseded rendered papers
book.zip
packets/*.zip
forcing_correspondence_v14.pdf
forcing_correspondence_v15.pdf

# Narration used Edge online TTS; redistribution grant not established
public/media/*.mp4
# Reproducible offline narration toolchain and generated audio
.venv-voice/
selfcompile/voices/models/
selfcompile/voices/rendered/
selfcompile/voices/videos/
