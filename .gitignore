dist/
dist-ssr/
*.local

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# logs
*.log
npm-debug.log*

# secrets — never commit keys or credentials
.env
.env.*
*.pem
*.key

