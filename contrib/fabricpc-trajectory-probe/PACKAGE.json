    "control_arms": [
      "process",
      "dense",
      "shuffled"
    ]
  },
  "implementation": "verification/tools/fabricpc_orientation_adapter.py",
  "certificate_builder": "verification/tools/fabricpc_orientation_sensor.py",
  "outputs": [
    "fabricpc_orientation_trace.json",
