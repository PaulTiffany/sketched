  "presentation": "contrib/fabricpc-trajectory-probe/presentation/index.html",
  "public_benchmark": {
    "name": "Tennessee Eastman Process Fault 1",
    "entrypoint": "contrib/fabricpc-trajectory-probe/tennessee-eastman/run.ps1",
    "trajectory_certificate": "verification/tep_fault1_certificate.json",
    "predictive_coding_certificate": "verification/tep_fabricpc_predictive_coding.json",
