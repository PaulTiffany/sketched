{
    "name":  "sketched",
    "private":  true,
    "version":  "0.0.0",
    "type":  "module",
    "description":  "Sketched is Chalked through time: a witnessed video stage where agents propose time-indexed layer mutations and the human holds authority.",
    "scripts":  {
                    "contribution:check":  "python verification/tools/contribution_audit.py",
                    "epistemology:check":  "python verification/tools/epistemology_audit.py",
                    "imagination:check":  "python verification/tools/imagination_certificate_audit.py",
                    "book:project":  "python verification/tools/book_projection.py",
                    "book:check":  "python verification/tools/book_projection.py --check",
                    "book:test":  "python verification/tools/test_book_projection.py",
                    "book:ledger":  "python verification/tools/book_ledger.py",
                    "book:glossary":  "python verification/tools/book_glossary.py",
                    "book5:lean":  "python verification/tools/book5_lean_coverage.py",
                    "ps:frontier":  "python verification/tools/ps_frontier.py",
                    "ps:frontier:check":  "python verification/tools/ps_frontier.py --check",
                    "ps:bindings":  "python verification/tools/binding_projection.py",
                    "ps:bindings:check":  "python verification/tools/binding_projection.py --check",
                    "ps:bindings:audit":  "python verification/tools/binding_audit.py",
                    "voice:check":  "python verification/tools/voice_audit.py",
                    "voice:render":  ".\\.venv-voice\\Scripts\\python.exe selfcompile/voices/render.py",
                    "video:render":  ".\\.venv-voice\\Scripts\\python.exe selfcompile/voices/video.py",
                    "video:check":  "python verification/tools/video_audit.py",
                    "content:check":  "npm run contribution:check \u0026\u0026 npm run epistemology:check \u0026\u0026 npm run imagination:check \u0026\u0026 npm run voice:check \u0026\u0026 npm run video:check \u0026\u0026 npm run book:check \u0026\u0026 npm run book:test \u0026\u0026 npm run book5:lean \u0026\u0026 npm run ps:frontier:check \u0026\u0026 npm run ps:bindings:check \u0026\u0026 npm run ps:bindings:audit",
                    "dev":  "npm run contribution:check \u0026\u0026 npm run book:ledger \u0026\u0026 npm run book:glossary \u0026\u0026 npm run book:project \u0026\u0026 npm run book5:lean \u0026\u0026 vite",
                    "build":  "npm run contribution:check \u0026\u0026 npm run epistemology:check \u0026\u0026 npm run imagination:check \u0026\u0026 npm run voice:check \u0026\u0026 npm run video:check \u0026\u0026 npm run book:ledger \u0026\u0026 npm run book:glossary \u0026\u0026 npm run book:project \u0026\u0026 npm run book5:lean \u0026\u0026 tsc -b \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "test":  "npm run content:check \u0026\u0026 npm run test:app",
                    "test:app":  "vitest run",
                    "test:watch":  "vitest",
                    "lint":  "eslint .",
                    "format":  "prettier --write ."
                },
    "dependencies":  {
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.14.0",
                            "@types/react":  "^18.3.12",
                            "@types/react-dom":  "^18.3.1",
                            "@typescript-eslint/eslint-plugin":  "^8.13.0",
                            "@typescript-eslint/parser":  "^8.13.0",
                            "@vitejs/plugin-react":  "^4.3.3",
                            "eslint":  "^9.14.0",
                            "eslint-plugin-react-hooks":  "^5.0.0",
                            "eslint-plugin-react-refresh":  "^0.4.14",
                            "prettier":  "^3.3.3",
                            "typescript":  "^5.6.3",
                            "vite":  "^5.4.10",
                            "vitest":  "^2.1.4"
                        },
